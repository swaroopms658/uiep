# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Required ---
SECRET_KEY=generate-a-long-random-string-here
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Database ---
# SQLite (local dev):
DATABASE_URL=sqlite:///./upi_tracker.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/upi_tracker

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# --- CORS (comma-separated allowed origins) ---
CORS_ORIGINS=http://localhost:19006,http://localhost:3000,exp://192.168.x.x:8081

# --- Connection pool (PostgreSQL only) ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Storage ---
STORAGE_TYPE=local
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_BUCKET_NAME=upi-tracker-uploads
# AWS_REGION=us-east-1
# CLOUDFLARE_ACCOUNT_ID=your_account_id

# --- Misc ---
DEBUG=false
SQLALCHEMY_ECHO=false
ACCESS_TOKEN_EXPIRE_MINUTES=30
